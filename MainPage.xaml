<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YoutubeMusic.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:models="clr-namespace:YoutubeMusic.Models"
             xmlns:local="clr-namespace:YoutubeMusic"

             x:Class="YoutubeMusic.MainPage"
             x:DataType="viewmodels:MainViewModel"
             BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgLight}}, Dark={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgDark}}}"
             Shell.NavBarIsVisible="False"
             Title="YouTube Music"
             x:Name="RootPage">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- WinUI 3 Color Palette (Adapts to system Light/Dark settings) -->
            <!-- WinUI 3 Accent Colors (Dynamic blue accent) -->
            <Color x:Key="WinUIAccentLight">#0067C0</Color>
            <Color x:Key="WinUIAccentDark">#28C6D0</Color> <!-- Screenbox Cyan -->

            <Color x:Key="WinUIBgLight">#F3F3F3</Color>
            <Color x:Key="WinUIBgDark">#20222B</Color> <!-- Screenbox Main Bg -->
            
            <Color x:Key="WinUISidebarBgLight">#F3F3F3</Color>
            <Color x:Key="WinUISidebarBgDark">#181A22</Color> <!-- Screenbox Sidebar Bg -->
            
            <Color x:Key="WinUICardBgLight">#FFFFFF</Color>
            <Color x:Key="WinUICardBgDark">#252733</Color> <!-- Screenbox Card/Row Bg -->
            
            <Color x:Key="WinUIBorderLight">#E0E0E0</Color>
            <Color x:Key="WinUIBorderDark">#2D2F3C</Color>
            
            <Color x:Key="WinUISeparatorLight">#D2D2D2</Color>
            <Color x:Key="WinUISeparatorDark">#2D2F3C</Color>

            <Color x:Key="WinUISelectedLight">#EAEAEA</Color>
            <Color x:Key="WinUISelectedDark">#2D2F3C</Color> <!-- Screenbox Row Hover/Selected -->

            <Color x:Key="WinUITextPrimaryLight">#000000</Color>
            <Color x:Key="WinUITextPrimaryDark">#FFFFFF</Color>

            <Color x:Key="WinUITextSecondaryLight">#5F5F5F</Color>
            <Color x:Key="WinUITextSecondaryDark">#8A8D98</Color>
            
            <Color x:Key="WinUICardBorderLight">#E5E5E5</Color>
            <Color x:Key="WinUICardBorderDark">#2D2F3C</Color>

            <Color x:Key="WinUIControlBgLight">#FFFFFF</Color>
            <Color x:Key="WinUIControlBgDark">#252733</Color>

            <Color x:Key="WinUIControlBorderLight">#CCCCCC</Color>
            <Color x:Key="WinUIControlBorderDark">#3C3C3C</Color>
            
            <!-- WinUI 3 Control Styles with theme adjustments -->
            <Style x:Key="WinUISecondaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EFEFEF, Dark=#2D2D2D}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Setter Property="BorderColor" Value="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="15,0" />
                <Setter Property="FontAttributes" Value="None" />
            </Style>

            <Style x:Key="WinUIPrimaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark=Black}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="15,0" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <!-- Windows 11 TitleBar injection (zpracovává se v code-behind) -->
    </ContentPage.Behaviors>

    <Grid>
        <Grid RowDefinitions="*, Auto, Auto">
        <!-- ZDE PRIDAVAME HIDDEN MEDIAELEMENT PRO PREHRAVANI -->
        <!-- Android ExoPlayer needs a real surface, so we place it behind everything (ZIndex=-1) with real dimensions -->
        <toolkit:MediaElement x:Name="AudioPlayer" Grid.RowSpan="3" ZIndex="-1" HorizontalOptions="Fill" VerticalOptions="Fill" ShouldAutoPlay="True" ShouldShowPlaybackControls="False" />
        <!-- Hlavní obsah (Sidebar + Content) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone=76, Default=76}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- SIDEBAR (NavigationView) -->
            <Grid Grid.Column="0" 
                  RowDefinitions="Auto, *, Auto" 
                  BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='#CCF3F3F3', Default={StaticResource WinUISidebarBgLight}}, Dark={OnPlatform WinUI='#CC202020', Default={StaticResource WinUISidebarBgDark}}}" 
                  Padding="12,15">
                
                <!-- Logo aplikace -->
                <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,15,0,25" HorizontalOptions="Center">
                    <Image Source="https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/Youtube_Music_icon.svg/512px-Youtube_Music_icon.svg.png" WidthRequest="36" HeightRequest="36" />
                </VerticalStackLayout>

                <!-- Navigační menu -->
                <VerticalStackLayout Grid.Row="1" Spacing="8">
                    <!-- Domů -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Home" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Home">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Home">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE80F;" />
                                            <On Platform="Default" Value="🏠" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextHome}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Hledat -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Search" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Search">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Search">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE721;" />
                                            <On Platform="Default" Value="🔍" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextSearch}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Knihovna -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Library" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Library">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Library">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8F1;" />
                                            <On Platform="Default" Value="📚" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextLibrary}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Fronta -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Queue" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Queue">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Queue">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8FD;" />
                                            <On Platform="Default" Value="≡" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextQueue}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Profil / Nastavení -->
                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,0,0,10">
                    <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" Margin="10,0,10,10" />
                    
                    <!-- Nastavení -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Settings" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Settings">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Settings">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE713;" />
                                            <On Platform="Default" Value="⚙" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextSettings}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Přihlášení (Ikona) -->
                    <Grid HeightRequest="56" IsVisible="{Binding IsNotLoggedIn}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Login" />
                        </Grid.GestureRecognizers>
                        
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE77B;" />
                                            <On Platform="Default" Value="👤" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="{Binding TextAccount}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- Profil (Přihlášený) -->
                    <Grid HeightRequest="56" IsVisible="{Binding IsLoggedIn}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Grid.GestureRecognizers>
                        
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" WidthRequest="24" HeightRequest="24" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="👤" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding TextLogout}" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <!-- Vertikální oddělovač (NavigationView Divider) -->
            <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" HorizontalOptions="End" VerticalOptions="Fill" />

            <!-- OBSAHOVÁ ČÁST (Mica Background Area) -->
            <Grid Grid.Column="1" 
                  RowDefinitions="Auto, *"
                  BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgLight}}, Dark={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgDark}}}" 
                  Padding="24,24,24,0">
                
                <!-- TOP HEADER BAR (Globální vyhledávání) -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <!-- Hledací lišta MS Store styl (vycentrovaná) -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource WinUIControlBgLight}, Dark={StaticResource WinUIControlBgDark}}" 
                            Stroke="{AppThemeBinding Light={StaticResource WinUIControlBorderLight}, Dark={StaticResource WinUIControlBorderDark}}" 
                            StrokeThickness="1" 
                            StrokeShape="RoundRectangle 20" 
                            Padding="15,0"
                            WidthRequest="{OnIdiom Phone=280, Default=500}"
                            HorizontalOptions="Center"
                            HeightRequest="40">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Label Grid.Column="0" VerticalOptions="Center" FontSize="14" Margin="0,0,12,0" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                                <Label.FontFamily>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                    </OnPlatform>
                                </Label.FontFamily>
                                <Label.Text>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="&#xE721;" />
                                        <On Platform="Default" Value="🔍" />
                                    </OnPlatform>
                                </Label.Text>
                            </Label>
                            <Entry Grid.Column="1" 
                                   Placeholder="{Binding TextSearchPlaceholder}" 
                                   Text="{Binding SearchQuery}" 
                                   TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"
                                   ReturnCommand="{Binding PerformSearchCommand}" />
                        </Grid>
                    </Border>
                    
                    <!-- Uživatelský profil nahoře vpravo -->
                    <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Center" Spacing="16" IsVisible="{Binding IsLoggedIn}">
                        <Label Text="{Binding UserProfileName}" VerticalOptions="Center" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 16" WidthRequest="32" HeightRequest="32" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}">
                            <Label Text="👤" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- VIEWS AREA -->
                <Grid Grid.Row="1">
                    
                    <!-- SEKCE: NASTAVENÍ -->
                    <Grid IsVisible="False">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Settings">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Grid.Triggers>
                        
                        <ScrollView>
                            <VerticalStackLayout Spacing="24" Padding="0,0,0,40">
                                <Label Text="{Binding TextSettings}" FontSize="36" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                
                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" 
                                        StrokeThickness="1" 
                                        BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" 
                                        StrokeShape="RoundRectangle 8" 
                                        Padding="20">
                                    <VerticalStackLayout Spacing="16">
                                        <Label Text="{Binding TextLanguageSelection}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                        <Label Text="{Binding TextLanguageDescription}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                        
                                        <Picker Title="{Binding TextLanguageSelection}"
                                                ItemsSource="{Binding Languages}"
                                                ItemDisplayBinding="{Binding NativeName}"
                                                SelectedItem="{Binding SelectedLanguage}"
                                                TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}"
                                                TitleColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}"
                                                BackgroundColor="{AppThemeBinding Light={StaticResource WinUIControlBgLight}, Dark={StaticResource WinUIControlBgDark}}"
                                                WidthRequest="300"
                                                HorizontalOptions="Start" />
                                    </VerticalStackLayout>
                                </Border>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>

                    <!-- 1. SEKCE: DOMŮ -->
                    <Grid IsVisible="False">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Home">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Grid.Triggers>
                        
                        <ScrollView>
                            <VerticalStackLayout Spacing="30" Padding="0,0,0,40">
                                
                                <!-- Doporučené skladby přímo pro vás (Knihovna) -->
                                <VerticalStackLayout Spacing="20" IsVisible="{Binding HasPersonalizedRecommendations}">
                                    <Label Text="{Binding TextPersonalizedSongs}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                    
                                    <FlexLayout BindableLayout.ItemsSource="{Binding LibraryBasedRecommendations}" 
                                                Wrap="Wrap" 
                                                JustifyContent="Center" 
                                                AlignItems="Start">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:SongModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" 
                                                        StrokeThickness="1" 
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" 
                                                        StrokeShape="RoundRectangle 8" 
                                                        WidthRequest="300" HeightRequest="100" 
                                                        Padding="12" Margin="12,0,12,24">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.PlaySongCommand, Source={x:Reference RootPage}}" CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" StrokeShape="RoundRectangle 8" Padding="0" BackgroundColor="Transparent" Stroke="Transparent" VerticalOptions="Center">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" LineBreakMode="TailTruncation" MaxLines="2" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                                            <Label Text="{Binding Artist}" FontSize="13" Margin="0,4,0,0" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>
                                </VerticalStackLayout>

                                <!-- Obecná Doporučená hudba -->
                                <VerticalStackLayout Spacing="20">
                                    <Label Text="{Binding TextRecommendedMusic}" FontSize="24" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                    
                                    <!-- Pokud se načítá, zobrazíme text -->
                                    <Label Text="{Binding TextLoadingRecommendations}" IsVisible="{Binding IsBusy}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                    
                                    <FlexLayout BindableLayout.ItemsSource="{Binding HomeRecommendations}" 
                                                Wrap="Wrap" 
                                                JustifyContent="Center" 
                                                AlignItems="Start">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:SongModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" 
                                                        StrokeThickness="1" 
                                                        BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" 
                                                        StrokeShape="RoundRectangle 8" 
                                                        WidthRequest="300" HeightRequest="100" 
                                                        Padding="12" Margin="12,0,12,24">
                                                    <Border.GestureRecognizers>
                                                        <TapGestureRecognizer Command="{Binding BindingContext.PlaySongCommand, Source={x:Reference RootPage}}" CommandParameter="{Binding .}" />
                                                    </Border.GestureRecognizers>
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <!-- Náhledový obrázek -->
                                                        <Border Grid.Column="0" WidthRequest="70" HeightRequest="70" StrokeShape="RoundRectangle 8" Padding="0" BackgroundColor="Transparent" Stroke="Transparent" VerticalOptions="Center">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" Margin="16,0,0,0" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" LineBreakMode="TailTruncation" MaxLines="2" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                                            <Label Text="{Binding Artist}" FontSize="13" Margin="0,4,0,0" LineBreakMode="TailTruncation" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </FlexLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>

                    <!-- 2. SEKCE: HLEDAT (Výsledky) -->
                    <Grid IsVisible="False" RowDefinitions="Auto, *">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Search">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Grid.Triggers>

                        <!-- Výsledky hledání ve stylu MS Store Cards -->
                        <CollectionView Grid.Row="1" 
                                        ItemsSource="{Binding SearchResults}"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedSong, Mode=TwoWay}">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=4}" VerticalItemSpacing="16" HorizontalItemSpacing="16" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SongModel">
                                    <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" 
                                            StrokeThickness="1" 
                                            StrokeShape="RoundRectangle 8" 
                                            BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" 
                                            HeightRequest="240">
                                        <Grid RowDefinitions="140, *">
                                            <!-- Thumbnail -->
                                            <Image Grid.Row="0" Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                            <!-- Content -->
                                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" MaxLines="2" />
                                                <Label Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            
                                            <!-- Značka / Ikona přehrání při najetí -->
                                            <Border Grid.Row="1" HorizontalOptions="End" VerticalOptions="Start" Margin="12" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14">
                                                <Label Text="▶" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Indikátor načítání -->
                        <ActivityIndicator Grid.Row="1" 
                                           IsRunning="{Binding IsBusy}" 
                                           IsVisible="{Binding IsBusy}" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"
                                           Color="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                    </Grid>

                <!-- 3. SEKCE: KNIHOVNA -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Library">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <!-- Obsah pro nepřihlášené -->
                    <VerticalStackLayout Grid.RowSpan="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" IsVisible="{Binding IsNotLoggedIn}">
                        <Label Text="{Binding TextLockedLibrary}" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" HorizontalOptions="Center" />
                        <Label Text="{Binding TextLockedLibraryDesc}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" HorizontalOptions="Center" HorizontalTextAlignment="Center" MaximumWidthRequest="350" FontSize="13" />
                        <Button Text="{Binding TextGoToLogin}" Command="{Binding NavigateCommand}" CommandParameter="Login" Style="{StaticResource WinUIPrimaryBtn}" HorizontalOptions="Center" WidthRequest="160" />
                    </VerticalStackLayout>

                    <!-- Obsah pro přihlášené -->
                    <Grid Grid.Row="0" Grid.RowSpan="2" RowDefinitions="Auto, *" IsVisible="{Binding IsLoggedIn}">
                        <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, *" Margin="0,0,0,24">
                            <!-- Nadpis a Taby -->
                            <HorizontalStackLayout Grid.Column="0" Spacing="24" VerticalOptions="End">
                                <Label Text="{Binding TextMusic}" FontSize="36" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" VerticalOptions="End" Margin="0,0,8,0" />
                                
                                <!-- Skladby -->
                                <Grid VerticalOptions="End" Margin="0,0,0,8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Songs" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="{Binding TextSongs}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Songs">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>

                                <!-- Alba -->
                                <Grid VerticalOptions="End" Margin="0,0,0,8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Albums" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="{Binding TextAlbums}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Albums">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>

                                <!-- Interpreti -->
                                <Grid VerticalOptions="End" Margin="0,0,0,8">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Artists" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="{Binding TextArtists}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Artists">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </HorizontalStackLayout>
                            
                            <!-- Add Folder -->
                            <Button Grid.Column="2" Text="{Binding TextAddFolder}" Command="{Binding NotImplementedCommand}" CommandParameter="Add folder" HorizontalOptions="End" VerticalOptions="Start" BackgroundColor="Transparent" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" BorderColor="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark={StaticResource WinUIBorderDark}}" BorderWidth="1" CornerRadius="6" HeightRequest="36" Padding="12,0" Margin="0,6,0,0">
                                <Button.ImageSource>
                                    <FontImageSource FontFamily="Segoe Fluent Icons" Glyph="&#xE8F4;" Color="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" Size="14" />
                                </Button.ImageSource>
                            </Button>
                        </Grid>

                        <Grid Grid.Row="1" RowDefinitions="Auto, *">
                            
                            <!-- Akční lišta: Shuffle and play / Sort -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *" Margin="0,0,0,24">
                                <Button Grid.Column="0" Text="{Binding TextShuffleAndPlay}" Command="{Binding ShuffleAndPlayLibraryCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" TextColor="{AppThemeBinding Light=White, Dark=Black}" FontAttributes="Bold" CornerRadius="6" HeightRequest="36" Padding="16,0">
                                    <Button.ImageSource>
                                        <FontImageSource FontFamily="Segoe Fluent Icons" Glyph="&#xE8B1;" Color="{AppThemeBinding Light=White, Dark=Black}" Size="14" />
                                    </Button.ImageSource>
                                </Button>
                                <HorizontalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="8">
                                    <HorizontalStackLayout.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding NotImplementedCommand}" CommandParameter="Filtrování a řazení" />
                                    </HorizontalStackLayout.GestureRecognizers>
                                    <Label Text="&#xE8CB;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" />
                                    <Label Text="{Binding TextSortBy}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="13" VerticalOptions="Center" />
                                    <Label Text="&#xE70D;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="10" VerticalOptions="Center" Margin="4,0,0,0" />
                                </HorizontalStackLayout>
                            </Grid>

                            <!-- Obsahy jednotlivých Tabů -->
                            <Grid Grid.Row="1">
                                <!-- Skladby tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Songs">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibrarySongs}" SelectionMode="Single" SelectedItem="{Binding SelectedSong, Mode=TwoWay}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:SongModel">
                                                <Border Stroke="Transparent" StrokeShape="RoundRectangle 8" BackgroundColor="Transparent" Padding="12,12">
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal" />
                                                            <VisualState x:Name="Selected">
                                                                <VisualState.Setters>
                                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EAEAEA, Dark={StaticResource WinUISelectedDark}}" />
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                    <Grid ColumnDefinitions="40, 3*, 2*, 2*, 2*, 60" ColumnSpacing="16" VerticalOptions="Center">
                                                        <Label Grid.Column="0" Text="&#xE768;" FontFamily="Segoe Fluent Icons" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUIAccentDark}}" VerticalOptions="Center" HorizontalOptions="Center" />
                                                        
                                                        <Label Grid.Column="1" Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                                        
                                                        <Label Grid.Column="2" Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUIAccentDark}}" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                                        
                                                        <Label Grid.Column="3" Text="{Binding Title}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                                        
                                                        <Label Grid.Column="4" Text="{Binding Source={RelativeSource AncestorType={x:Type local:MainPage}}, Path=BindingContext.TextUnknownGenre}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" LineBreakMode="TailTruncation" VerticalOptions="Center" />
                                                        
                                                        <Label Grid.Column="5" Text="3:31" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" HorizontalOptions="End" VerticalOptions="Center" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Playlisty tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Playlists">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryPlaylists}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:PlaylistModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="15">
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" HeightRequest="44" WidthRequest="44" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding Creator}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            <Label TextColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" FontSize="10">
                                                                <Label.Text>
                                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                                        <Binding Path="BindingContext.TextSongsCountLabel" Source="{RelativeSource AncestorType={x:Type local:MainPage}}" />
                                                                        <Binding Path="SongCount" />
                                                                    </MultiBinding>
                                                                </Label.Text>
                                                            </Label>                                                        </VerticalStackLayout>
                                                        <Button Grid.Column="2" 
                                                                Text="{Binding BindingContext.TextPlay, Source={x:Reference RootPage}}" 
                                                                Command="{Binding BindingContext.PlayPlaylistCommand, Source={x:Reference RootPage}}"
                                                                CommandParameter="{Binding .}"
                                                                Style="{StaticResource WinUISecondaryBtn}"
                                                                VerticalOptions="Center" 
                                                                HeightRequest="30"
                                                                Padding="10,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Alba tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Albums">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryAlbums}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:AlbumModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="15">
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" HeightRequest="44" WidthRequest="44" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding ArtistName}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            <Label TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="10">
                                                                <Label.Text>
                                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                                        <Binding Path="BindingContext.TextReleaseYearLabel" Source="{RelativeSource AncestorType={x:Type local:MainPage}}" />
                                                                        <Binding Path="ReleaseYear" />
                                                                    </MultiBinding>
                                                                </Label.Text>
                                                            </Label>                                                        </VerticalStackLayout>
                                                        <Button Grid.Column="2" 
                                                                Text="{Binding BindingContext.TextPlay, Source={x:Reference RootPage}}" 
                                                                Command="{Binding BindingContext.PlayAlbumCommand, Source={x:Reference RootPage}}"
                                                                CommandParameter="{Binding .}"
                                                                Style="{StaticResource WinUISecondaryBtn}"
                                                                VerticalOptions="Center" 
                                                                HeightRequest="30"
                                                                Padding="10,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Interpreti tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Artists">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryArtists}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:ArtistModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="44, *" ColumnSpacing="15">
                                                        <!-- Kruhové ohraničení pro interprety (WinUI 3 standard) -->
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 22" HeightRequest="44" WidthRequest="44">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11">
                                                                <Label.Text>
                                                                    <MultiBinding StringFormat="{}{0} {1}">
                                                                        <Binding Path="BindingContext.TextSongsCountLabel" Source="{RelativeSource AncestorType={x:Type local:MainPage}}" />
                                                                        <Binding Path="SongCount" />
                                                                    </MultiBinding>
                                                                </Label.Text>
                                                            </Label>                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Indikátor načítání -->
                    <ActivityIndicator Grid.Row="1" 
                                       IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"
                                       Color="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                </Grid>

                <!-- 4. SEKCE: PŘIHLÁŠENÍ -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Login">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <!-- Informační panel WebView -->
                    <Border Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="16" Margin="0,0,0,16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="{Binding TextLoginInstructions}" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" FontSize="14" />
                            <Label Text="{Binding TextLoginInstruction1}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" />
                            <Label Text="{Binding TextLoginInstruction2}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- WebView pro Google Sign-In -->
                    <WebView Grid.Row="1" 
                             x:Name="LoginWebView" 
                             Source="https://music.youtube.com/" 
                             Navigated="OnLoginWebViewNavigated" />
                </Grid>

                <!-- 5. SEKCE: FRONTA -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Queue">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="{Binding TextPlaybackQueue}" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            <Label TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="13">
                                <Label.Text>
                                    <MultiBinding StringFormat="{}{0} {1}">
                                        <Binding Path="TextSongsInQueueLabel" />
                                        <Binding Path="PlaybackQueue.Count" />
                                    </MultiBinding>
                                </Label.Text>
                            </Label>                        </VerticalStackLayout>
                        <Button Grid.Column="1" 
                                Text="{Binding TextClearQueue}" 
                                Command="{Binding ClearQueueCommand}" 
                                Style="{StaticResource WinUISecondaryBtn}" 
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- Queue List -->
                    <CollectionView Grid.Row="1" 
                                    ItemsSource="{Binding PlaybackQueue}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedQueueSong, Mode=TwoWay}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SongModel">
                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#D2E8FF, Dark=#2A3D50}" />
                                                    <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                                                    <Setter Property="StrokeThickness" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    
                                    <Grid ColumnDefinitions="48, *, Auto" ColumnSpacing="15">
                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4" HeightRequest="44" WidthRequest="44">
                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2" VerticalOptions="Center" Margin="0,0,10,0" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}">
                                            <Label.FontFamily>
                                                <OnPlatform x:TypeArguments="x:String">
                                                    <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                                </OnPlatform>
                                            </Label.FontFamily>
                                            <Label.Text>
                                                <OnPlatform x:TypeArguments="x:String">
                                                    <On Platform="WinUI" Value="&#xE768;" />
                                                    <On Platform="Default" Value="▶" />
                                                </OnPlatform>
                                            </Label.Text>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty state -->
                    <VerticalStackLayout Grid.Row="1" 
                                         VerticalOptions="Center" 
                                         HorizontalOptions="Center" 
                                         Spacing="12" 
                                         IsVisible="{Binding IsCurrentSongNull}">
                        <Label Text="{Binding TextEmptyQueue}" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" HorizontalOptions="Center" />
                        <Label Text="{Binding TextEmptyQueueDesc}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="13" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
                <!-- ZDE JE PŘIDÁN ZAVÍRACÍ TAG PRO VIEWS AREA (Grid.Row=1) -->
                </Grid>
            </Grid>
        </Grid>

                <!-- SPODNÍ PANEL PŘEHRÁVAČE (Screenbox Floating Bar) -->
        <Grid Grid.Row="1" 
              IsVisible="{OnIdiom Phone=False, Default=True}"
              HeightRequest="116" 
              BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='#F3F3F3', Default={StaticResource WinUICardBgLight}}, Dark={OnPlatform WinUI='#222431', Default={StaticResource WinUICardBgDark}}}" 
              Margin="24,0,24,24"
              VerticalOptions="End"
              ColumnDefinitions="116, *" 
              Padding="0">
            
            <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Grid.ColumnSpan="2" BackgroundColor="Transparent" ZIndex="-1" />

            <!-- Levá část: Velký obrázek -->
            <Grid Grid.Column="0" IsVisible="{Binding IsCurrentSongNotNull}">
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12,0,12,0">
                    <Image Source="{Binding CurrentSong.ThumbnailUrl}" Aspect="AspectFill" />
                </Border>
                <Border BackgroundColor="#80000000" Stroke="Transparent" StrokeShape="RoundRectangle 16" WidthRequest="32" HeightRequest="32" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,8,0,0">
                    <Label Text="&#xE70E;" FontFamily="Segoe Fluent Icons" TextColor="White" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
            </Grid>

            <!-- Pravá část: Info, Slider, Controls -->
            <Grid Grid.Column="1" RowDefinitions="46, Auto, *" Padding="16,10,16,8">
                <!-- Info (Title, Artist) -->
                <VerticalStackLayout Grid.Row="0" Spacing="0" VerticalOptions="Center" IsVisible="{Binding IsCurrentSongNotNull}">
                    <Label Text="{Binding CurrentSong.Title}" FontFamily="OpenSansSemibold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                    <Label Text="{Binding CurrentSong.Artist}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
                <Label Grid.Row="0" Text="Žádná skladba nehraje" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" FontAttributes="Italic" VerticalOptions="Center" IsVisible="{Binding IsCurrentSongNull}" />

                <!-- Progress Bar -->
                <Slider Grid.Row="1" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds}" DragStarted="OnSliderDragStarted" DragCompleted="OnSliderDragCompleted" MinimumTrackColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" MaximumTrackColor="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" ThumbColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" Margin="0" HeightRequest="20" />

                <!-- Controls Area -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto, Auto, *">
                    <!-- Hlavní Playback tlačítka -->
                    <HorizontalStackLayout Grid.Column="0" Spacing="16" VerticalOptions="Center">
                        <Button Command="{Binding PlayPauseCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="30" HeightRequest="30" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                            <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                            <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE768;" /><On Platform="Default" Value="▶" /></OnPlatform></Button.Text>
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                    <Setter Property="Text"><Setter.Value><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE769;" /><On Platform="Default" Value="⏸" /></OnPlatform></Setter.Value></Setter>
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Command="{Binding PreviousCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="30" HeightRequest="30" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                            <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                            <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE892;" /><On Platform="Default" Value="⏮" /></OnPlatform></Button.Text>
                        </Button>
                        <Button Command="{Binding NextSongCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="30" HeightRequest="30" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                            <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                            <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE893;" /><On Platform="Default" Value="⏭" /></OnPlatform></Button.Text>
                        </Button>
                    </HorizontalStackLayout>
                    
                    <!-- Time Label -->
                    <Label Grid.Column="1" FontSize="11" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" Margin="16,0,0,0">
                        <Label.Text>
                            <MultiBinding StringFormat="{}{0} / {1}">
                                <Binding Path="PositionText" />
                                <Binding Path="DurationText" />
                            </MultiBinding>
                        </Label.Text>
                    </Label>

                    <!-- Pravé nástroje (Volume, Shuffle, Repeat atd.) -->
                    <HorizontalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="16">
                        <!-- Volume -->
                        <Label Text="&#xE767;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" VerticalOptions="Center" FontSize="14" />
                        <Slider Minimum="0" Maximum="1" Value="{Binding Volume}" WidthRequest="80" VerticalOptions="Center" MinimumTrackColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" MaximumTrackColor="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" ThumbColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                        <!-- Shuffle Button -->
                        <Button Command="{Binding ToggleShuffleCommand}" BackgroundColor="Transparent" Padding="0" Margin="0" VerticalOptions="Center" MinimumHeightRequest="24" WidthRequest="24" HeightRequest="24" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                            <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                            <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8B1;" /><On Platform="Default" Value="🔀" /></OnPlatform></Button.Text>
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding IsShuffle}" Value="True">
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Button Command="{Binding ToggleRepeatCommand}" BackgroundColor="Transparent" Padding="0" Margin="0" VerticalOptions="Center" MinimumHeightRequest="24" WidthRequest="24" HeightRequest="24">
                            <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="0">
                                    <Setter Property="Text"><Setter.Value><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8EE;" /><On Platform="Default" Value="🔁" /></OnPlatform></Setter.Value></Setter>
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="1">
                                    <Setter Property="Text"><Setter.Value><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8EE;" /><On Platform="Default" Value="🔁" /></OnPlatform></Setter.Value></Setter>
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                                </DataTrigger>
                                <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="2">
                                    <Setter Property="Text"><Setter.Value><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8EF;" /><On Platform="Default" Value="🔂" /></OnPlatform></Setter.Value></Setter>
                                    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>
                        <Label Text="&#xE713;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" FontSize="14" />
                        <Label Text="&#xE73F;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" FontSize="14" />
                        <Label Text="&#xE712;" FontFamily="Segoe Fluent Icons" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" FontSize="14" />
                    </HorizontalStackLayout>
                </Grid>
            </Grid>
        </Grid>

    </Grid>
    </Grid>

</ContentPage>