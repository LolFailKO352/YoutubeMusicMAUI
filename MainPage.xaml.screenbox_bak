<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:YoutubeMusic.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:models="clr-namespace:YoutubeMusic.Models"

             x:Class="YoutubeMusic.MainPage"
             x:DataType="viewmodels:MainViewModel"
             BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgLight}}, Dark={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgDark}}}"
             Title="YouTube Music">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- WinUI 3 Color Palette (Adapts to system Light/Dark settings) -->
            <!-- WinUI 3 Accent Colors (Dynamic blue accent) -->
            <Color x:Key="WinUIAccentLight">#0067C0</Color>
            <Color x:Key="WinUIAccentDark">#60CDFF</Color>

            <Color x:Key="WinUIBgLight">#F3F3F3</Color>
            <Color x:Key="WinUIBgDark">#1C1C1C</Color>
            
            <Color x:Key="WinUISidebarBgLight">#F3F3F3</Color>
            <Color x:Key="WinUISidebarBgDark">#202020</Color>
            
            <Color x:Key="WinUICardBgLight">#FFFFFF</Color>
            <Color x:Key="WinUICardBgDark">#272727</Color>
            
            <Color x:Key="WinUIBorderLight">#E0E0E0</Color>
            <Color x:Key="WinUIBorderDark">#323232</Color>
            
            <Color x:Key="WinUISeparatorLight">#D2D2D2</Color>
            <Color x:Key="WinUISeparatorDark">#2D2D2D</Color>

            <Color x:Key="WinUISelectedLight">#EAEAEA</Color>
            <Color x:Key="WinUISelectedDark">#2D2D2D</Color>

            <Color x:Key="WinUITextPrimaryLight">#000000</Color>
            <Color x:Key="WinUITextPrimaryDark">#FFFFFF</Color>

            <Color x:Key="WinUITextSecondaryLight">#5F5F5F</Color>
            <Color x:Key="WinUITextSecondaryDark">#A0A0A0</Color>
            
            <Color x:Key="WinUICardBorderLight">#E5E5E5</Color>
            <Color x:Key="WinUICardBorderDark">#323232</Color>

            <Color x:Key="WinUIControlBgLight">#FFFFFF</Color>
            <Color x:Key="WinUIControlBgDark">#2D2D2D</Color>

            <Color x:Key="WinUIControlBorderLight">#CCCCCC</Color>
            <Color x:Key="WinUIControlBorderDark">#3C3C3C</Color>
            
            <!-- WinUI 3 Control Styles with theme adjustments -->
            <Style x:Key="WinUISecondaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#EFEFEF, Dark=#2D2D2D}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#000000, Dark=#FFFFFF}" />
                <Setter Property="BorderColor" Value="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="15,0" />
                <Setter Property="FontAttributes" Value="None" />
            </Style>

            <Style x:Key="WinUIPrimaryBtn" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                <Setter Property="TextColor" Value="{AppThemeBinding Light=White, Dark=Black}" />
                <Setter Property="CornerRadius" Value="4" />
                <Setter Property="HeightRequest" Value="36" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="15,0" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <!-- Windows 11 TitleBar injection (zpracovává se v code-behind) -->
    </ContentPage.Behaviors>

    <Grid>
        <Grid RowDefinitions="*, Auto, Auto">
        <!-- ZDE PRIDAVAME HIDDEN MEDIAELEMENT PRO PREHRAVANI -->
        <!-- Android ExoPlayer needs a real surface, so we place it behind everything (ZIndex=-1) with real dimensions -->
        <toolkit:MediaElement x:Name="AudioPlayer" Grid.RowSpan="3" ZIndex="-1" HorizontalOptions="Fill" VerticalOptions="Fill" ShouldAutoPlay="True" ShouldShowPlaybackControls="False" />
        <!-- Hlavní obsah (Sidebar + Content) -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{OnIdiom Phone=76, Default=76}" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- SIDEBAR (NavigationView) -->
            <Grid Grid.Column="0" 
                  RowDefinitions="Auto, *, Auto" 
                  BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='#CCF3F3F3', Default={StaticResource WinUISidebarBgLight}}, Dark={OnPlatform WinUI='#CC202020', Default={StaticResource WinUISidebarBgDark}}}" 
                  Padding="12,15">
                
                <!-- Logo aplikace -->
                <VerticalStackLayout Grid.Row="0" Spacing="10" Margin="0,15,0,25" HorizontalOptions="Center">
                    <Image Source="https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/Youtube_Music_icon.svg/512px-Youtube_Music_icon.svg.png" WidthRequest="36" HeightRequest="36" />
                </VerticalStackLayout>

                <!-- Navigační menu -->
                <VerticalStackLayout Grid.Row="1" Spacing="8">
                    <!-- Domů -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Home" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Home">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Home">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE80F;" />
                                            <On Platform="Default" Value="🏠" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="Domů" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Hledat -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Search" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Search">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Search">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE721;" />
                                            <On Platform="Default" Value="🔍" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="Hledat" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Knihovna -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Library" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Library">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Library">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8F1;" />
                                            <On Platform="Default" Value="📚" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="Knihovna" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Fronta -->
                    <Grid HeightRequest="56">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Queue" />
                        </Grid.GestureRecognizers>
                        
                        <BoxView WidthRequest="3" HeightRequest="24" CornerRadius="1.5" HorizontalOptions="Start" VerticalOptions="Center" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" IsVisible="False">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding CurrentView}" Value="Queue">
                                    <Setter Property="IsVisible" Value="True" />
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>

                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding CurrentView}" Value="Queue">
                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource WinUISelectedLight}, Dark={StaticResource WinUISelectedDark}}" />
                                </DataTrigger>
                            </Border.Triggers>
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8FD;" />
                                            <On Platform="Default" Value="≡" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="Fronta" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- Profil / Nastavení -->
                <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,0,0,10">
                    <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" Margin="10,0,10,10" />
                    
                    <!-- Přihlášení (Ikona) -->
                    <Grid HeightRequest="56" IsVisible="{Binding IsNotLoggedIn}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Login" />
                        </Grid.GestureRecognizers>
                        
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                                    <Label.FontFamily>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                        </OnPlatform>
                                    </Label.FontFamily>
                                    <Label.Text>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE77B;" />
                                            <On Platform="Default" Value="👤" />
                                        </OnPlatform>
                                    </Label.Text>
                                </Label>
                                <Label Text="Účet" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    
                    <!-- Profil (Přihlášený) -->
                    <Grid HeightRequest="56" IsVisible="{Binding IsLoggedIn}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding LogoutCommand}" />
                        </Grid.GestureRecognizers>
                        
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 6" BackgroundColor="Transparent" Padding="0,6" Margin="8,0,8,0">
                            <VerticalStackLayout Spacing="2" VerticalOptions="Center" HorizontalOptions="Center">
                                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" WidthRequest="24" HeightRequest="24" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="👤" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Odhlásit" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </Grid>

            <!-- Vertikální oddělovač (NavigationView Divider) -->
            <BoxView Grid.Column="0" WidthRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" HorizontalOptions="End" VerticalOptions="Fill" />

            <!-- OBSAHOVÁ ČÁST (Mica Background Area) -->
            <Grid Grid.Column="1" 
                  RowDefinitions="Auto, *"
                  BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgLight}}, Dark={OnPlatform WinUI='Transparent', Default={StaticResource WinUIBgDark}}}" 
                  Padding="24,24,24,0">
                
                <!-- TOP HEADER BAR (Globální vyhledávání) -->
                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <!-- Hledací lišta MS Store styl (vycentrovaná) -->
                    <Border BackgroundColor="{AppThemeBinding Light={StaticResource WinUIControlBgLight}, Dark={StaticResource WinUIControlBgDark}}" 
                            Stroke="{AppThemeBinding Light={StaticResource WinUIControlBorderLight}, Dark={StaticResource WinUIControlBorderDark}}" 
                            StrokeThickness="1" 
                            StrokeShape="RoundRectangle 20" 
                            Padding="15,0"
                            WidthRequest="{OnIdiom Phone=280, Default=500}"
                            HorizontalOptions="Center"
                            HeightRequest="40">
                        <Grid ColumnDefinitions="Auto, *, Auto">
                            <Label Grid.Column="0" VerticalOptions="Center" FontSize="14" Margin="0,0,12,0" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                                <Label.FontFamily>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                    </OnPlatform>
                                </Label.FontFamily>
                                <Label.Text>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="&#xE721;" />
                                        <On Platform="Default" Value="🔍" />
                                    </OnPlatform>
                                </Label.Text>
                            </Label>
                            <Entry Grid.Column="1" 
                                   Placeholder="Vyhledat aplikace, hry a další (nebo hudbu!)" 
                                   Text="{Binding SearchQuery}" 
                                   TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}"
                                   PlaceholderColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}"
                                   BackgroundColor="Transparent"
                                   VerticalOptions="Center"
                                   ReturnCommand="{Binding PerformSearchCommand}" />
                        </Grid>
                    </Border>
                    
                    <!-- Uživatelský profil nahoře vpravo -->
                    <HorizontalStackLayout HorizontalOptions="End" VerticalOptions="Center" Spacing="16" IsVisible="{Binding IsLoggedIn}">
                        <Label Text="{Binding UserProfileName}" VerticalOptions="Center" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                        <Border Stroke="Transparent" StrokeShape="RoundRectangle 16" WidthRequest="32" HeightRequest="32" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}">
                            <Label Text="👤" FontSize="16" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                    </HorizontalStackLayout>
                </Grid>

                <!-- VIEWS AREA -->
                <Grid Grid.Row="1">
                    
                    <!-- 1. SEKCE: DOMŮ -->
                    <Grid IsVisible="False">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Home">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Grid.Triggers>
                        
                        <ScrollView>
                            <VerticalStackLayout Spacing="30" Padding="0,0,0,40">
                                
                                <!-- HERO BANNER -->
                                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" BackgroundColor="#00A25C" HeightRequest="300" Padding="40">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#00C969" Offset="0.0" />
                                            <GradientStop Color="#006A3A" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="15">
                                            <Label Text="YouTube Music" FontSize="42" FontAttributes="Bold" TextColor="White" />
                                            <Label Text="Poslouchej hudbu bez omezení a bez reklam" TextColor="White" FontSize="18" Opacity="0.9" />
                                            <Button Text="Začít poslouchat" 
                                                    Command="{Binding NavigateCommand}" 
                                                    CommandParameter="Search"
                                                    BackgroundColor="White" 
                                                    TextColor="Black" 
                                                    FontAttributes="Bold" 
                                                    CornerRadius="6" 
                                                    HeightRequest="40" 
                                                    WidthRequest="160"
                                                    HorizontalOptions="Start" 
                                                    Margin="0,20,0,0" />
                                        </VerticalStackLayout>
                                        
                                        <!-- Fake Image on Right -->
                                        <Image Grid.Column="1" Source="https://upload.wikimedia.org/wikipedia/commons/thumb/6/6a/Youtube_Music_icon.svg/512px-Youtube_Music_icon.svg.png" WidthRequest="180" HeightRequest="180" VerticalOptions="Center" Margin="0,0,20,0" Opacity="0.8" />
                                    </Grid>
                                </Border>

                                <!-- Populární hudba (Mock Carousel) -->
                                <VerticalStackLayout Spacing="15">
                                    <Label Text="Nejoblíbenější vyhledávání &gt;" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                    <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                                        <HorizontalStackLayout Spacing="16">
                                            <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" StrokeShape="RoundRectangle 8" WidthRequest="280" HeightRequest="80" Padding="12">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <BoxView Grid.Column="0" WidthRequest="56" HeightRequest="56" CornerRadius="8" BackgroundColor="#E53935" />
                                                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                                        <Label Text="Top 50 - Global" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                                        <Label Text="Nejhranější skladby" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                            <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" StrokeShape="RoundRectangle 8" WidthRequest="280" HeightRequest="80" Padding="12">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <BoxView Grid.Column="0" WidthRequest="56" HeightRequest="56" CornerRadius="8" BackgroundColor="#1E88E5" />
                                                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                                        <Label Text="Pop Hits 2026" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                                        <Label Text="Nové a populární" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                            <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" StrokeThickness="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" StrokeShape="RoundRectangle 8" WidthRequest="280" HeightRequest="80" Padding="12">
                                                <Grid ColumnDefinitions="Auto, *">
                                                    <BoxView Grid.Column="0" WidthRequest="56" HeightRequest="56" CornerRadius="8" BackgroundColor="#8E24AA" />
                                                    <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                                        <Label Text="Chill Lofi Beats" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                                        <Label Text="K učení a práci" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                                                    </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </ScrollView>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </ScrollView>
                    </Grid>

                    <!-- 2. SEKCE: HLEDAT (Výsledky) -->
                    <Grid IsVisible="False" RowDefinitions="Auto, *">
                        <Grid.Triggers>
                            <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Search">
                                <Setter Property="IsVisible" Value="True" />
                            </DataTrigger>
                        </Grid.Triggers>

                        <!-- Výsledky hledání ve stylu MS Store Cards -->
                        <CollectionView Grid.Row="1" 
                                        ItemsSource="{Binding SearchResults}"
                                        SelectionMode="Single"
                                        SelectedItem="{Binding SelectedSong, Mode=TwoWay}">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="{OnIdiom Phone=1, Tablet=2, Desktop=4}" VerticalItemSpacing="16" HorizontalItemSpacing="16" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SongModel">
                                    <Border Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" 
                                            StrokeThickness="1" 
                                            StrokeShape="RoundRectangle 8" 
                                            BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" 
                                            HeightRequest="240">
                                        <Grid RowDefinitions="140, *">
                                            <!-- Thumbnail -->
                                            <Image Grid.Row="0" Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                            <!-- Content -->
                                            <VerticalStackLayout Grid.Row="1" Padding="12" Spacing="4">
                                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="14" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" MaxLines="2" />
                                                <Label Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                            
                                            <!-- Značka / Ikona přehrání při najetí -->
                                            <Border Grid.Row="1" HorizontalOptions="End" VerticalOptions="Start" Margin="12" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14">
                                                <Label Text="▶" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <!-- Indikátor načítání -->
                        <ActivityIndicator Grid.Row="1" 
                                           IsRunning="{Binding IsBusy}" 
                                           IsVisible="{Binding IsBusy}" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center"
                                           Color="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                    </Grid>

                <!-- 3. SEKCE: KNIHOVNA -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Library">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <!-- Obsah pro nepřihlášené -->
                    <VerticalStackLayout Grid.RowSpan="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="16" IsVisible="{Binding IsNotLoggedIn}">
                        <Label Text="Uzamčená Knihovna" FontSize="20" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" HorizontalOptions="Center" />
                        <Label Text="Chcete-li zobrazit své skladby, playlisty a alba z YouTube Music, musíte se přihlásit." TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" HorizontalOptions="Center" HorizontalTextAlignment="Center" MaximumWidthRequest="350" FontSize="13" />
                        <Button Text="Přejít k přihlášení" Command="{Binding NavigateCommand}" CommandParameter="Login" Style="{StaticResource WinUIPrimaryBtn}" HorizontalOptions="Center" WidthRequest="160" />
                    </VerticalStackLayout>

                    <!-- Obsah pro přihlášené -->
                    <Grid Grid.Row="0" Grid.RowSpan="2" RowDefinitions="Auto, *" IsVisible="{Binding IsLoggedIn}">
                        <Label Grid.Row="0" Text="Moje Knihovna" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" Margin="0,0,0,16" />

                        <Grid Grid.Row="1" RowDefinitions="Auto, *">
                            
                            <!-- Záložky (Knihovna Taby v Pivot Stylu) -->
                            <Grid Grid.Row="0" ColumnDefinitions="Auto, Auto, Auto, Auto" ColumnSpacing="24" Margin="0,0,0,16" HeightRequest="35">
                                <!-- Skladby -->
                                <Grid Grid.Column="0">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Songs" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="Skladby" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Songs">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <BoxView HeightRequest="2.5" CornerRadius="1.25" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" VerticalOptions="End" HorizontalOptions="Fill" IsVisible="False">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding LibraryTab}" Value="Songs">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                </Grid>

                                <!-- Playlisty -->
                                <Grid Grid.Column="1">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Playlists" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="Playlisty" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Playlists">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <BoxView HeightRequest="2.5" CornerRadius="1.25" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" VerticalOptions="End" HorizontalOptions="Fill" IsVisible="False">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding LibraryTab}" Value="Playlists">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                </Grid>

                                <!-- Alba -->
                                <Grid Grid.Column="2">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Albums" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="Alba" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Albums">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <BoxView HeightRequest="2.5" CornerRadius="1.25" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" VerticalOptions="End" HorizontalOptions="Fill" IsVisible="False">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding LibraryTab}" Value="Albums">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                </Grid>

                                <!-- Interpreti -->
                                <Grid Grid.Column="3">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SetLibraryTabCommand}" CommandParameter="Artists" />
                                    </Grid.GestureRecognizers>
                                    <Label Text="Interpreti" FontSize="14" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" HorizontalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding LibraryTab}" Value="Artists">
                                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <BoxView HeightRequest="2.5" CornerRadius="1.25" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" VerticalOptions="End" HorizontalOptions="Fill" IsVisible="False">
                                        <BoxView.Triggers>
                                            <DataTrigger TargetType="BoxView" Binding="{Binding LibraryTab}" Value="Artists">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </BoxView.Triggers>
                                    </BoxView>
                                </Grid>
                            </Grid>

                            <!-- Obsahy jednotlivých Tabů -->
                            <Grid Grid.Row="1">
                                <!-- Skladby tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Songs">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibrarySongs}" SelectionMode="Single" SelectedItem="{Binding SelectedSong, Mode=TwoWay}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:SongModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="44, *, Auto" ColumnSpacing="12">
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" HeightRequest="38" WidthRequest="38" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                                        </VerticalStackLayout>
                                                        <Label Grid.Column="2" VerticalOptions="Center" Margin="0,0,10,0" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}">
                                                            <Label.FontFamily>
                                                                <OnPlatform x:TypeArguments="x:String">
                                                                    <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                                                </OnPlatform>
                                                            </Label.FontFamily>
                                                            <Label.Text>
                                                                <OnPlatform x:TypeArguments="x:String">
                                                                    <On Platform="WinUI" Value="&#xE768;" />
                                                                    <On Platform="Default" Value="▶" />
                                                                </OnPlatform>
                                                            </Label.Text>
                                                        </Label>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Playlisty tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Playlists">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryPlaylists}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:PlaylistModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="15">
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" HeightRequest="44" WidthRequest="44" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding Creator}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding SongCount, StringFormat='Skladeb: {0}'}" TextColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" FontSize="10" />
                                                        </VerticalStackLayout>
                                                        <Button Grid.Column="2" 
                                                                Text="Přehrát" 
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=PlayPlaylistCommand}"
                                                                CommandParameter="{Binding .}"
                                                                Style="{StaticResource WinUISecondaryBtn}"
                                                                VerticalOptions="Center" 
                                                                HeightRequest="30"
                                                                Padding="10,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Alba tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Albums">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryAlbums}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:AlbumModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="50, *, Auto" ColumnSpacing="15">
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" HeightRequest="44" WidthRequest="44" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding ArtistName}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding ReleaseYear, StringFormat='Rok: {0}'}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="10" />
                                                        </VerticalStackLayout>
                                                        <Button Grid.Column="2" 
                                                                Text="Přehrát" 
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:MainViewModel}}, Path=PlayAlbumCommand}"
                                                                CommandParameter="{Binding .}"
                                                                Style="{StaticResource WinUISecondaryBtn}"
                                                                VerticalOptions="Center" 
                                                                HeightRequest="30"
                                                                Padding="10,0" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>

                                <!-- Interpreti tab -->
                                <Grid IsVisible="False">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding LibraryTab}" Value="Artists">
                                            <Setter Property="IsVisible" Value="True" />
                                        </DataTrigger>
                                    </Grid.Triggers>
                                    <CollectionView ItemsSource="{Binding LibraryArtists}">
                                        <CollectionView.ItemTemplate>
                                            <DataTemplate x:DataType="models:ArtistModel">
                                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                                    <Grid ColumnDefinitions="44, *" ColumnSpacing="15">
                                                        <!-- Kruhové ohraničení pro interprety (WinUI 3 standard) -->
                                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 22" HeightRequest="44" WidthRequest="44">
                                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                                        </Border>
                                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                            <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                                            <Label Text="{Binding SongCount, StringFormat='Skladeb: {0}'}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" />
                                                        </VerticalStackLayout>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </CollectionView.ItemTemplate>
                                    </CollectionView>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Indikátor načítání -->
                    <ActivityIndicator Grid.Row="1" 
                                       IsRunning="{Binding IsBusy}" 
                                       IsVisible="{Binding IsBusy}" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center"
                                       Color="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                </Grid>

                <!-- 4. SEKCE: PŘIHLÁŠENÍ -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Login">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <!-- Informační panel WebView -->
                    <Border Grid.Row="0" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUICardBgDark}}" Stroke="{AppThemeBinding Light={StaticResource WinUICardBorderLight}, Dark={StaticResource WinUICardBorderDark}}" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="16" Margin="0,0,0,16">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="💡 Instrukce pro přihlášení" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" FontSize="14" />
                            <Label Text="1. Přihlaste se ke svému Google / YouTube účtu přímo v okně níže." TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" />
                            <Label Text="2. Po úspěšném přihlášení a načtení hlavní stránky YouTube Music vás aplikace automaticky připojí a stáhne vaši osobní knihovnu." TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- WebView pro Google Sign-In -->
                    <WebView Grid.Row="1" 
                             x:Name="LoginWebView" 
                             Source="https://music.youtube.com/" 
                             Navigated="OnLoginWebViewNavigated" />
                </Grid>

                <!-- 5. SEKCE: FRONTA -->
                <Grid Grid.Row="1" IsVisible="False" RowDefinitions="Auto, *">
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding CurrentView}" Value="Queue">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                    </Grid.Triggers>

                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,16">
                        <VerticalStackLayout Grid.Column="0" Spacing="4">
                            <Label Text="Fronta přehrávání" FontSize="28" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" />
                            <Label Text="{Binding PlaybackQueue.Count, StringFormat='Skladeb ve frontě: {0}'}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="13" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" 
                                Text="Vyčistit frontu" 
                                Command="{Binding ClearQueueCommand}" 
                                Style="{StaticResource WinUISecondaryBtn}" 
                                VerticalOptions="Center" />
                    </Grid>

                    <!-- Queue List -->
                    <CollectionView Grid.Row="1" 
                                    ItemsSource="{Binding PlaybackQueue}"
                                    SelectionMode="Single"
                                    SelectedItem="{Binding SelectedQueueSong, Mode=TwoWay}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SongModel">
                                <Border Stroke="{AppThemeBinding Light={StaticResource WinUIBorderLight}, Dark=Transparent}" StrokeThickness="1" StrokeShape="RoundRectangle 4" BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark=#202020}" Margin="0,0,0,6" Padding="10,8">
                                    <VisualStateManager.VisualStateGroups>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal" />
                                            <VisualState x:Name="Selected">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#D2E8FF, Dark=#2A3D50}" />
                                                    <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                                                    <Setter Property="StrokeThickness" Value="1" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateManager.VisualStateGroups>
                                    
                                    <Grid ColumnDefinitions="48, *, Auto" ColumnSpacing="15">
                                        <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4" HeightRequest="44" WidthRequest="44">
                                            <Image Source="{Binding ThumbnailUrl}" Aspect="AspectFill" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                            <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                                            <Label Text="{Binding Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2" VerticalOptions="Center" Margin="0,0,10,0" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}">
                                            <Label.FontFamily>
                                                <OnPlatform x:TypeArguments="x:String">
                                                    <On Platform="WinUI" Value="Segoe Fluent Icons" />
                                                </OnPlatform>
                                            </Label.FontFamily>
                                            <Label.Text>
                                                <OnPlatform x:TypeArguments="x:String">
                                                    <On Platform="WinUI" Value="&#xE768;" />
                                                    <On Platform="Default" Value="▶" />
                                                </OnPlatform>
                                            </Label.Text>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty state -->
                    <VerticalStackLayout Grid.Row="1" 
                                         VerticalOptions="Center" 
                                         HorizontalOptions="Center" 
                                         Spacing="12" 
                                         IsVisible="{Binding IsCurrentSongNull}">
                        <Label Text="Fronta je prázdná" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" HorizontalOptions="Center" />
                        <Label Text="Najděte nějaké skladby a spusťte přehrávání." TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="13" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>
                <!-- ZDE JE PŘIDÁN ZAVÍRACÍ TAG PRO VIEWS AREA (Grid.Row=1) -->
                </Grid>
            </Grid>
        </Grid>

        <!-- SPODNÍ PANEL PŘEHRÁVAČE (Windows 11 Media style - POUZE DESKTOP) -->
        <Grid Grid.Row="1" 
              IsVisible="{OnIdiom Phone=False, Default=True}"
              HeightRequest="95" 
              BackgroundColor="{AppThemeBinding Light={OnPlatform WinUI='#DDFFFFFF', Default={StaticResource WinUICardBgLight}}, Dark={OnPlatform WinUI='#DD202020', Default={StaticResource WinUISidebarBgDark}}}" 
              ColumnDefinitions="280, *, 280" 
              Padding="15,0" 
              VerticalOptions="End">
            
            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" VerticalOptions="Start" Grid.ColumnSpan="3" Margin="-15,0" />

            <!-- Levá část: Detaily skladby -->
            <Grid Grid.Column="0" ColumnDefinitions="48, *" ColumnSpacing="12" VerticalOptions="Center" IsVisible="{Binding IsCurrentSongNotNull}">
                <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4" HeightRequest="44" WidthRequest="44">
                    <Image Source="{Binding CurrentSong.ThumbnailUrl}" Aspect="AspectFill" />
                </Border>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="{Binding CurrentSong.Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                    <Label Text="{Binding CurrentSong.Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
                </VerticalStackLayout>
            </Grid>
            
            <Label Grid.Column="0" Text="Žádná skladba nehraje" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="12" FontAttributes="Italic" VerticalOptions="Center" HorizontalOptions="Center" IsVisible="{Binding IsCurrentSongNull}" />

            <!-- Střední část: Ovládání přehrávání a časová osa -->
            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                <!-- Tlačítka přehrávače -->
                <HorizontalStackLayout Spacing="16" HorizontalOptions="Center" VerticalOptions="Center">
                    <!-- Shuffle Button -->
                    <Button Command="{Binding ToggleShuffleCommand}" 
                            BackgroundColor="Transparent" 
                            WidthRequest="36" 
                            HeightRequest="36"
                            Padding="0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.Text>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="&#xE8B1;" />
                                <On Platform="Default" Value="🔀" />
                            </OnPlatform>
                        </Button.Text>
                        <Button.TextColor>
                            <AppThemeBindingExtension Light="{StaticResource WinUITextSecondaryLight}" Dark="{StaticResource WinUITextSecondaryDark}" />
                        </Button.TextColor>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsShuffle}" Value="True">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Button Command="{Binding PlayPreviousSongCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" 
                            WidthRequest="36" 
                            HeightRequest="36"
                            Padding="0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.Text>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="&#xE892;" />
                                <On Platform="Default" Value="⏮" />
                            </OnPlatform>
                        </Button.Text>
                    </Button>
                    
                    <Button Command="{Binding PlayPauseCommand}" 
                            BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" 
                            TextColor="{AppThemeBinding Light=White, Dark=Black}" 
                            WidthRequest="38" 
                            HeightRequest="38" 
                            CornerRadius="19"
                            Padding="0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE769;" />
                                            <On Platform="Default" Value="⏸" />
                                        </OnPlatform>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="False">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE768;" />
                                            <On Platform="Default" Value="▶" />
                                        </OnPlatform>
                                    </Setter.Value>
                                </Setter>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    
                    <Button Command="{Binding PlayNextSongCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" 
                            WidthRequest="36" 
                            HeightRequest="36"
                            Padding="0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.Text>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="&#xE893;" />
                                <On Platform="Default" Value="⏭" />
                            </OnPlatform>
                        </Button.Text>
                    </Button>

                    <!-- Repeat Button -->
                    <Button Command="{Binding ToggleRepeatCommand}" 
                            BackgroundColor="Transparent" 
                            WidthRequest="36" 
                            HeightRequest="36"
                            Padding="0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.TextColor>
                            <AppThemeBindingExtension Light="{StaticResource WinUITextSecondaryLight}" Dark="{StaticResource WinUITextSecondaryDark}" />
                        </Button.TextColor>
                        <Button.Triggers>
                            <!-- Repeat Mode 0 (Off) -->
                            <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="0">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8EE;" />
                                            <On Platform="Default" Value="🔁" />
                                        </OnPlatform>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" />
                            </DataTrigger>
                            <!-- Repeat Mode 1 (Queue) -->
                            <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="1">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8EE;" />
                                            <On Platform="Default" Value="🔁" />
                                        </OnPlatform>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                            </DataTrigger>
                            <!-- Repeat Mode 2 (Song) -->
                            <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="2">
                                <Setter Property="Text">
                                    <Setter.Value>
                                        <OnPlatform x:TypeArguments="x:String">
                                            <On Platform="WinUI" Value="&#xE8EF;" />
                                            <On Platform="Default" Value="🔂" />
                                        </OnPlatform>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </HorizontalStackLayout>

                <!-- Časová osa -->
                <Grid ColumnDefinitions="40, *, 40" ColumnSpacing="8" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="{Binding PositionText}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" HorizontalOptions="End" VerticalOptions="Center" />
                    
                    <Slider Grid.Column="1" 
                            x:Name="PositionSlider"
                            Minimum="0" 
                            Maximum="{Binding DurationSeconds}" 
                            Value="{Binding PositionSeconds}"
                            MinimumTrackColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" 
                            MaximumTrackColor="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" 
                            ThumbColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}"
                            DragStarted="OnSliderDragStarted"
                            DragCompleted="OnSliderDragCompleted"
                            VerticalOptions="Center"
                            HeightRequest="15" />
                    
                    <Label Grid.Column="2" Text="{Binding DurationText}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" HorizontalOptions="Start" VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

            <!-- Pravá část: Hlasitost a stavové zprávy (Grid o 2 řádcích pro zamezení ořezu textu) -->
            <Grid Grid.Column="2" RowDefinitions="*, Auto" VerticalOptions="Center" HorizontalOptions="End" WidthRequest="250">
                <HorizontalStackLayout Grid.Row="0" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                    <!-- Queue Toggle Button -->
                    <Button Command="{Binding NavigateCommand}" 
                            CommandParameter="Queue"
                            BackgroundColor="Transparent" 
                            WidthRequest="36" 
                            HeightRequest="36"
                            Padding="0"
                            Margin="0,0,8,0">
                        <Button.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Button.FontFamily>
                        <Button.Text>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="&#xE8FD;" />
                                <On Platform="Default" Value="≡" />
                            </OnPlatform>
                        </Button.Text>
                        <Button.TextColor>
                            <AppThemeBindingExtension Light="{StaticResource WinUITextSecondaryLight}" Dark="{StaticResource WinUITextSecondaryDark}" />
                        </Button.TextColor>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding CurrentView}" Value="Queue">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>

                    <Label VerticalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="14">
                        <Label.FontFamily>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="Segoe Fluent Icons" />
                            </OnPlatform>
                        </Label.FontFamily>
                        <Label.Text>
                            <OnPlatform x:TypeArguments="x:String">
                                <On Platform="WinUI" Value="&#xE767;" />
                                <On Platform="Default" Value="🔊" />
                            </OnPlatform>
                        </Label.Text>
                    </Label>
                    <Slider x:Name="VolumeSlider" 
                            WidthRequest="130" 
                            Minimum="0" 
                            Maximum="1" 
                            Value="{Binding Volume, Mode=TwoWay}" 
                            MinimumTrackColor="{AppThemeBinding Light=#5F5F5F, Dark=White}" 
                            MaximumTrackColor="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" 
                            ThumbColor="{AppThemeBinding Light=#5F5F5F, Dark=White}"
                            VerticalOptions="Center"
                            HeightRequest="15" />
                </HorizontalStackLayout>
                
                <Label Grid.Row="1" 
                       Text="{Binding StatusMessage}" 
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#FF9F0A}" 
                       FontSize="10" 
                       HorizontalOptions="End" 
                       HorizontalTextAlignment="End"
                       LineBreakMode="CharacterWrap"
                       Margin="0,2,0,0" />
            </Grid>
            <!-- Audio: stažení přes YouTubeMusicService, demux fMP4->AAC a přehrání přes NAudio (WindowsAudioService) -->
        </Grid>

        <!-- SPODNÍ PANEL PŘEHRÁVAČE (MOBILNÍ) -->
        <Grid Grid.Row="1"
              IsVisible="{OnIdiom Phone=True, Default=False}"
              HeightRequest="60"
              BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUISidebarBgDark}}"
              ColumnDefinitions="Auto, *, Auto"
              Padding="10,0"
              VerticalOptions="End">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleFullScreenPlayerCommand}" />
            </Grid.GestureRecognizers>
            
            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" VerticalOptions="Start" Grid.ColumnSpan="3" Margin="-10,0" />

            <!-- Progress bar nahoře -->
            <ProgressBar Grid.ColumnSpan="3" VerticalOptions="Start" Margin="-10,0" HeightRequest="2" ProgressColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" Progress="{Binding ProgressRatio}" />

            <!-- Thumbnail -->
            <Border Grid.Column="0" Stroke="Transparent" StrokeShape="RoundRectangle 4" HeightRequest="40" WidthRequest="40" VerticalOptions="Center">
                <Image Source="{Binding CurrentSong.ThumbnailUrl}" Aspect="AspectFill" />
            </Border>

            <!-- Texty -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0">
                <Label Text="{Binding CurrentSong.Title}" FontAttributes="Bold" FontSize="13" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                <Label Text="{Binding CurrentSong.Artist}" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" FontSize="11" LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <!-- Tlačítko Play/Pause -->
            <Button Grid.Column="2"
                    Command="{Binding PlayPauseCommand}"
                    BackgroundColor="Transparent"
                    WidthRequest="40"
                    HeightRequest="40"
                    Padding="0"
                    VerticalOptions="Center">
                <Button.FontFamily>
                    <OnPlatform x:TypeArguments="x:String">
                        <On Platform="WinUI" Value="Segoe Fluent Icons" />
                    </OnPlatform>
                </Button.FontFamily>
                <Button.Text>
                    <OnPlatform x:TypeArguments="x:String">
                        <On Platform="WinUI" Value="&#xE768;" />
                        <On Platform="Default" Value="▶" />
                    </OnPlatform>
                </Button.Text>
                <Button.TextColor>
                    <AppThemeBindingExtension Light="{StaticResource WinUITextPrimaryLight}" Dark="{StaticResource WinUITextPrimaryDark}" />
                </Button.TextColor>
                <Button.Triggers>
                    <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                        <Setter Property="Text">
                            <Setter.Value>
                                <OnPlatform x:TypeArguments="x:String">
                                    <On Platform="WinUI" Value="&#xE769;" />
                                    <On Platform="Default" Value="⏸" />
                                </OnPlatform>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Button.Triggers>
            </Button>
        </Grid>

        <!-- MOBILNÍ SPODNÍ NAVIGACE -->
        <Grid Grid.Row="2"
              IsVisible="{OnIdiom Phone=True, Default=False}"
              HeightRequest="56"
              BackgroundColor="{AppThemeBinding Light={StaticResource WinUISidebarBgLight}, Dark={StaticResource WinUISidebarBgDark}}"
              ColumnDefinitions="*,*,*,*"
              Padding="0">
            <BoxView HeightRequest="1" BackgroundColor="{AppThemeBinding Light={StaticResource WinUISeparatorLight}, Dark={StaticResource WinUISeparatorDark}}" VerticalOptions="Start" Grid.ColumnSpan="4" />

            <!-- Home -->
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Home" />
                </VerticalStackLayout.GestureRecognizers>
                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Label.FontFamily>
                    <Label.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE80F;" /><On Platform="Default" Value="🏠" /></OnPlatform></Label.Text>
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Home"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="Domů" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Home"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- Search -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Search" />
                </VerticalStackLayout.GestureRecognizers>
                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Label.FontFamily>
                    <Label.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE721;" /><On Platform="Default" Value="🔍" /></OnPlatform></Label.Text>
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Search"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="Hledat" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Search"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- Library -->
            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Library" />
                </VerticalStackLayout.GestureRecognizers>
                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Label.FontFamily>
                    <Label.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8F1;" /><On Platform="Default" Value="📚" /></OnPlatform></Label.Text>
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Library"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="Knihovna" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Library"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>

            <!-- Queue -->
            <VerticalStackLayout Grid.Column="3" VerticalOptions="Center" HorizontalOptions="Center" Spacing="2">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Queue" />
                </VerticalStackLayout.GestureRecognizers>
                <Label HorizontalOptions="Center" FontSize="18" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Label.FontFamily>
                    <Label.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8FD;" /><On Platform="Default" Value="≡" /></OnPlatform></Label.Text>
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Queue"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="Fronta" FontSize="10" HorizontalOptions="Center" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding CurrentView}" Value="Queue"><Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" /></DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>
    </Grid>
    </Grid>

        <!-- PLNOOBRAZOVKOVÝ PŘEHRÁVAČ (FULL SCREEN OVERLAY) -->
        <Grid IsVisible="{Binding IsFullScreenPlayerVisible}"
              BackgroundColor="{AppThemeBinding Light={StaticResource WinUICardBgLight}, Dark={StaticResource WinUISidebarBgDark}}"
              RowDefinitions="Auto, *, Auto, Auto"
              Padding="20, 40, 20, 20">
            
            <!-- Horní lišta s tlačítkem dolů -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,20">
                <Button Grid.Column="0" Command="{Binding ToggleFullScreenPlayerCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="40" HeightRequest="40">
                    <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                    <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE70D;" /><On Platform="Default" Value="▼" /></OnPlatform></Button.Text>
                    <Button.TextColor><AppThemeBindingExtension Light="{StaticResource WinUITextPrimaryLight}" Dark="{StaticResource WinUITextPrimaryDark}" /></Button.TextColor>
                </Button>
                <!-- Zde by mohlo být menu nebo Cast ikona (Grid.Column=2) -->
            </Grid>

            <!-- Obal alba uprostřed -->
            <Border Grid.Row="1" Stroke="Transparent" StrokeShape="RoundRectangle 12" HorizontalOptions="Center" VerticalOptions="Center" Margin="20">
                <Image Source="{Binding CurrentSong.ThumbnailUrl}" Aspect="AspectFill" WidthRequest="300" HeightRequest="300" />
            </Border>

            <!-- Texty (Název a Autor) -->
            <VerticalStackLayout Grid.Row="2" Margin="0, 20">
                <Label Text="{Binding CurrentSong.Title}" FontAttributes="Bold" FontSize="22" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}" LineBreakMode="TailTruncation" />
                <Label Text="{Binding CurrentSong.Artist}" FontSize="16" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" LineBreakMode="TailTruncation" Margin="0,5,0,0" />
            </VerticalStackLayout>

            <!-- Ovládání (Timeline a Tlačítka) -->
            <VerticalStackLayout Grid.Row="3" Spacing="10">
                <!-- Timeline Slider -->
                <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" VerticalOptions="Center">
                    <Label Grid.Column="0" Text="{Binding PositionText}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" />
                    <Slider Grid.Column="1" Minimum="0" Maximum="{Binding DurationSeconds}" Value="{Binding PositionSeconds}" DragStarted="OnSliderDragStarted" DragCompleted="OnSliderDragCompleted" MinimumTrackColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" MaximumTrackColor="{AppThemeBinding Light=#D2D2D2, Dark=#3C3C3C}" ThumbColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                    <Label Grid.Column="2" Text="{Binding DurationText}" FontSize="12" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}" VerticalOptions="Center" />
                </Grid>

                <!-- Hlavní Playback tlačítka -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="25" Margin="0,10,0,0">
                    <Button Command="{Binding ToggleShuffleCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="50" HeightRequest="50" TextColor="{AppThemeBinding Light={StaticResource WinUITextSecondaryLight}, Dark={StaticResource WinUITextSecondaryDark}}">
                        <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                        <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE8B1;" /><On Platform="Default" Value="🔀" /></OnPlatform></Button.Text>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsShuffle}" Value="True">
                                <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    
                    <Button Command="{Binding PreviousCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="50" HeightRequest="50" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                        <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                        <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE892;" /><On Platform="Default" Value="⏮" /></OnPlatform></Button.Text>
                    </Button>
                    
                    <Button Command="{Binding PlayPauseCommand}" BackgroundColor="{AppThemeBinding Light={StaticResource WinUIAccentLight}, Dark={StaticResource WinUIAccentDark}}" CornerRadius="35" WidthRequest="70" HeightRequest="70" Padding="0" TextColor="White">
                        <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                        <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE768;" /><On Platform="Default" Value="▶" /></OnPlatform></Button.Text>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                <Setter Property="Text"><Setter.Value><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE769;" /><On Platform="Default" Value="⏸" /></OnPlatform></Setter.Value></Setter>
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                    
                    <Button Command="{Binding NextCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="50" HeightRequest="50" TextColor="{AppThemeBinding Light={StaticResource WinUITextPrimaryLight}, Dark={StaticResource WinUITextPrimaryDark}}">
                        <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                        <Button.Text><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="&#xE893;" /><On Platform="Default" Value="⏭" /></OnPlatform></Button.Text>
                    </Button>

                    <Button Command="{Binding ToggleRepeatCommand}" BackgroundColor="Transparent" Padding="0" WidthRequest="50" HeightRequest="50">
                        <Button.FontFamily><OnPlatform x:TypeArguments="x:String"><On Platform="WinUI" Value="Segoe Fluent Icons" /></OnPlatform></Button.FontFamily>
                        <Button.Triggers>
                            <DataTrigger TargetType="Button" Binding="{Binding RepeatMode}" Value="0">
